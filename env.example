# ------------------------------------------------------------------------------
# RAG Doc QA environment template
# Copy this file to .env and fill in the values for your local setup.
# ------------------------------------------------------------------------------

# PostgreSQL / pgvector connection
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/DBNAME

# ----------------------------------------------------------------------
# Model / API configuration
# Uncomment and fill in the variables that match your actual setup.
# ----------------------------------------------------------------------

# Example: Gemini / Google AI Studio
# GEMINI_API_KEY=your_gemini_api_key_here

# Example: OpenAI-compatible setup
# OPENAI_API_KEY=your_openai_api_key_here

# Optional: if your code supports explicit model names
# EMBEDDING_MODEL=
# GENERATION_MODEL=

# ----------------------------------------------------------------------
# App behavior
# Uncomment only if your code reads these from environment variables.
# Otherwise keep using the constants in code.
# ----------------------------------------------------------------------

# FILTER_MAX_COSINE_DISTANCE=0.85
# REFUSE_IF_BEST_DISTANCE_GT=0.75
# CACHE_TTL_SECONDS=300

# ----------------------------------------------------------------------
# Optional app server settings
# ----------------------------------------------------------------------

# HOST=127.0.0.1
# PORT=8000
